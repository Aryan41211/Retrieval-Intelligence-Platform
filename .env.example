# Retrieval Intelligence Platform - Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to version control

# =============================================================================
# Application Settings
# =============================================================================
APP_NAME=retrieval-intelligence-platform
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# =============================================================================
# Ingestion Configuration
# =============================================================================
INGESTION_MAX_FILE_SIZE_MB=100
INGESTION_DEFAULT_ENCODING=utf-8
INGESTION_DEFAULT_LANGUAGE=en

# =============================================================================
# Chunking Configuration
# =============================================================================
CHUNKING_CHUNK_SIZE=512
CHUNKING_CHUNK_OVERLAP=50
CHUNKING_MIN_CHUNK_SIZE=50
CHUNKING_MAX_CHUNK_SIZE=1024
CHUNKING_STRATEGY=recursive

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/app.log

# =============================================================================
# Data Paths
# =============================================================================
DATA_DIR=backend/data
RAW_DATA_DIR=backend/data/raw
PROCESSED_DATA_DIR=backend/data/processed
MODEL_DIR=backend/data/models
VECTOR_STORE_DIR=backend/data/vectorstore

# =============================================================================
# Embedding Providers (configure as needed)
# =============================================================================
# OpenAI
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_BASE=https://api.openai.com/v1

# Cohere
COHERE_API_KEY=
COHERE_EMBEDDING_MODEL=embed-english-v3.0

# Voyage AI
VOYAGE_API_KEY=
VOYAGE_EMBEDDING_MODEL=voyage-3

# Local / Self-hosted (Sentence Transformers)
SENTENCE_TRANSFORMERS_MODEL=BAAI/bge-small-en-v1.5
SENTENCE_TRANSFORMERS_DEVICE=cpu

# =============================================================================
# Vector Store Configuration
# =============================================================================
VECTOR_STORE_PROVIDER=faiss
VECTOR_STORE_PATH=backend/data/vectorstore/index

# Pinecone
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=rip-index

# Chroma
CHROMA_PERSIST_DIRECTORY=backend/data/vectorstore/chroma
CHROMA_COLLECTION_NAME=documents

# Weaviate
WEAVIATE_URL=
WEAVIATE_API_KEY=
WEAVIATE_CLASS_NAME=Document

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=documents

# =============================================================================
# LLM Providers (configure as needed)
# =============================================================================
# OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.1

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Ollama (Local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# vLLM / TGI (Self-hosted)
VLLM_BASE_URL=
VLLM_MODEL=
TGI_BASE_URL=
TGI_MODEL=

# =============================================================================
# Retrieval Configuration
# =============================================================================
RETRIEVAL_TOP_K=10
RETRIEVAL_RERANK_TOP_K=5
RETRIEVAL_SIMILARITY_THRESHOLD=0.7
RETRIEVAL_HYBRID_ALPHA=0.5
RETRIEVAL_BM25_ENABLED=true
RETRIEVAL_DENSE_ENABLED=true

# Reranker
RERANKER_PROVIDER=cohere
COHERE_RERANK_MODEL=rerank-english-v3.0
JINA_RERANK_MODEL=jina-reranker-v2-base-multilingual

# =============================================================================
# Generation Configuration
# =============================================================================
GENERATION_MAX_CONTEXT_TOKENS=8192
GENERATION_MAX_OUTPUT_TOKENS=2048
GENERATION_TEMPERATURE=0.1
GENERATION_TOP_P=0.95
GENERATION_CITATION_ENABLED=true

# =============================================================================
# Evaluation Configuration
# =============================================================================
EVALUATION_BATCH_SIZE=32
EVALUATION_SAMPLE_SIZE=100
EVALUATION_METRICS=faithfulness,answer_relevancy,context_precision,context_recall

# RAGAS
RAGAS_API_KEY=

# DeepEval
DEEPEVAL_API_KEY=

# =============================================================================
# Experiment Tracking
# =============================================================================
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_EXPERIMENT_NAME=rip-experiments
MLFLOW_ARTIFACT_ROOT=mlruns

WANDB_API_KEY=
WANDB_PROJECT=retrieval-intelligence-platform
WANDB_ENTITY=

# =============================================================================
# Database (for metadata, experiments, etc.)
# =============================================================================
DATABASE_URL=sqlite:///backend/data/rip.db
DATABASE_ECHO=false

# PostgreSQL (Production)
# DATABASE_URL=postgresql://user:password@localhost:5432/rip

# =============================================================================
# Caching
# =============================================================================
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# =============================================================================
# Monitoring & Observability
# =============================================================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=retrieval-intelligence-platform
OTEL_INSECURE=true

PROMETHEUS_METRICS_PORT=9090
GRAFANA_DASHBOARD_URL=

# =============================================================================
# Feature Flags
# =============================================================================
FEATURE_HYBRID_SEARCH=true
FEATURE_RERANKING=true
FEATURE_QUERY_EXPANSION=true
FEATURE_CITATION_GENERATION=true
FEATURE_EXPLAINABLE_RETRIEVAL=true

# =============================================================================
# Security
# =============================================================================
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8501"]

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# =============================================================================
# API Runtime (FastAPI process) - prefixed with API_
# These drive the running web server: binding, CORS, logging, security
# headers, rate limiting and observability. Never hardcode secrets here.
# =============================================================================
# deployment environment: development | staging | production
API_ENVIRONMENT=development
# bind address/port for the container (override with $PORT on platforms)
API_HOST=0.0.0.0
API_PORT=8000
# structured JSON logging is recommended for production log aggregation
API_LOG_FORMAT=json
API_LOG_LEVEL=INFO
# disable interactive docs in production (set to false)
API_DOCS_ENABLED=true
# CORS: use explicit origins in production; avoid "*" with credentials
API_CORS_ORIGINS=["http://localhost:3000"]
API_CORS_CREDENTIALS=false
API_CORS_METHODS=["GET","POST","PUT","DELETE","OPTIONS","PATCH"]
API_CORS_HEADERS=["*"]
# rate limiting (in-memory token bucket per client IP)
API_RATE_LIMIT_PER_MINUTE=120
API_RATE_LIMIT_BURST=20
# baseline HTTP security headers; enable HSTS only behind TLS
API_SECURITY_HEADERS_ENABLED=true
API_HSTS_ENABLED=false
API_CSP_POLICY=default-src 'self'
# Prometheus metrics endpoint (/api/v1/metrics)
API_PROMETHEUS_ENABLED=true
# expose correlation id under this response/request header
API_CORRELATION_HEADER=X-Correlation-ID